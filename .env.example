# Production: values from Cloudflare Access > Applications > your application
CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
CF_ACCESS_AUD=replace-with-application-audience-tag
# Base64-encoded 32-byte key used only by the Worker to encrypt client credentials.
CREDENTIAL_ENCRYPTION_KEY=replace-with-base64-32-byte-key
PORT=8787

# Local development only. The bypass is rejected unless the server is bound to loopback.
DEV_AUTH_BYPASS=true
DEV_AUTH_EMAIL=owner@kindredinnovia.com
